{
  "manifest_version": 3,
  "name": "ImgLab",
  "description": "A powerful all-in-one image toolkit — resize, crop, convert formats, extract colors, remove backgrounds, and encode to Base64, all without leaving your browser.",
  "version": "1.0",
  "permissions": ["sidePanel", "activeTab"],
  "side_panel": {
    "default_path": "src/panel/index.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "ImgLab",
    "default_icon": {
      "32": "logo_32.png",
      "48": "logo_48.png",
      "128": "logo_128.png"
    }
  },
  "icons": {
    "32": "logo_32.png",
    "48": "logo_48.png",
    "64": "logo_64.png",
    "128": "logo_128.png"
  }
}